{
  "name": "aura",
  "version": "1.1.0",
  "description": "Offline Electron application",
  "main": "main.js",
  "scripts": {
    "rebuild-native": "electron-rebuild -f -w better-sqlite3 || true",
    "dev": "vite",
    "desktop": "cross-env AURA_USE_VITE=1 concurrently -k \"node ./node_modules/vite/bin/vite.js --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && ./node_modules/.bin/electron .\"",
    "build": "echo '🔨 Сборка renderer + Electron…' && vite build && electron-builder --dir",
    "build:mac": "echo '🍎 Создание установщика AURA для macOS...' && vite build && electron-builder --mac",
    "build:mac:arm64": "echo '🍎 ARM Создание установщика AURA для Apple Silicon...' && vite build && electron-builder --mac --arm64",
    "build:mac:universal": "echo '🍎 Universal Создание универсального установщика для всех macOS...' && vite build && electron-builder --mac -p always"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/i18next": "^12.1.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "dmg-license": "^1.0.11",
    "electron": "^25.9.8",
    "electron-builder": "^24.0.0",
    "electron-rebuild": "^3.2.9",
    "tailwindcss": "^4.1.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.aura.app",
    "productName": "Aura 1.1",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!node_modules/**/*",
      "!.git/**/*",
      "!.cursor/**/*",
      "!.claude/**/*"
    ],
    "win": {
      "icon": "public/icon.ico"
    },
    "mac": {
      "icon": "public/icon.png",
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": null,
      "signIgnore": [
        "**/*.node"
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "artifactName": "${productName}-${version}.${ext}"
    }
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "i18next": "^26.0.8",
    "lucide-react": "^0.503.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.6",
    "tailwind-merge": "^3.2.0"
  }
}
