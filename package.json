{
  "name": "aura",
  "version": "1.1.0",
  "description": "Offline Electron application",
  "main": "main.js",
  "scripts": {
    "desktop": "concurrently -k \"node server-mini-app/index.js\" \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env AURA_USE_VITE=1 electron .\"",
    "build": "echo '🔨 Сборка renderer + Electron…' && vite build && electron-builder --dir",
    "build:mac": "echo '🍎 Создание установщика AURA для macOS...' && vite build && electron-builder --mac",
    "clear-db": "echo '🗑️  Очистка базы данных...' && node scripts/clear-db-standalone.js"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "dmg-license": "^1.0.11",
    "electron": "^25.9.8",
    "electron-builder": "^24.0.0",
    "electron-rebuild": "^3.2.9",
    "tailwindcss": "^4.1.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.aura.app",
    "productName": "Aura 1.1",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "renderer-build/**/*",
      "!dist/**/*",
      "!scripts/**/*",
      "!.cursor/**/*",
      "!.git/**/*",
      "!.claude/**/*"
    ],
    "win": {
      "icon": "public/icon.ico"
    },
    "mac": {
      "icon": "public/icon.png",
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "identity": null
    }
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.503.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.2.0"
  }
}
